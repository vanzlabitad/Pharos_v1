#!/usr/bin/env bash
# Pharos pre-commit hook — runs the secret scanner against staged files only.
#
# Install (one-off, per clone):
#     git config core.hooksPath .githooks
#
# Bypass (don't): --no-verify. The CI workflow re-runs the same scan on
# push/PR, so bypassing locally just means the rejection happens on GitHub
# instead. Use the bypass for legitimate false positives only and follow up
# by adding to the allowlist in scripts/check-secrets.sh.

set -euo pipefail

# Staged files only (added or modified, not deleted).
mapfile -t staged < <(git diff --cached --name-only --diff-filter=ACM)

if (( ${#staged[@]} == 0 )); then
    exit 0
fi

bash scripts/check-secrets.sh "${staged[@]}"
