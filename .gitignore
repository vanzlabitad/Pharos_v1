# Database
db/pharos.db

# Environment — catch every variant so secrets cannot accidentally land
# anywhere in the tree. The Next.js conventions (.env.local, .env.production
# etc.) are particularly easy to commit because they look like config files.
.env
.env.*
*.env
!.env.example
dashboard/.env*

# Python
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/
dist/
build/
.venv/
venv/

# Data (large raw files at project root only)
/data/

# Quarto rendered outputs — regenerated on demand, not committed
analysis/report.html
analysis/report.pdf
analysis/report.tex
analysis/*_files/
.quarto/

# Node / dashboard (added later)
dashboard/node_modules/
dashboard/.next/
dashboard/.vercel/
dashboard/out/

# Session handover docs — local working notes, not for the public repo
HANDOFF.md
HANDOFF-*.md

# Claude Code working directory (per-project state, worktrees, settings)
.claude/
